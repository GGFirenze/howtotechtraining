# ---------------------------------------------------------------------------
# CrackVILT — environment variables
# Copy this file to .env.local and fill in values for your environment.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser bundle.
# Everything else stays server-side only.
# ---------------------------------------------------------------------------

# --- Site --------------------------------------------------------------------
# Public, canonical URL of the deployment. Used for OG/canonical tags and
# any place we need to build absolute links (emails, webhooks).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Supabase (Milestone 3) --------------------------------------------------
# Project URL and the anon key (safe to expose; RLS denies all by default).
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service role key — server-only, NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=""

# --- Lemon Squeezy (Milestone 4) --------------------------------------------
# Webhook signing secret from LS dashboard → Settings → Webhooks → Signing
# secret. Server-only — used by /api/webhook/lemonsqueezy to verify HMAC.
LEMONSQUEEZY_WEBHOOK_SECRET=""

# Public checkout URL of the product (LS dashboard → Products → Share → Buy
# now URL, e.g. https://crackvilt.lemonsqueezy.com/buy/xxxx-xxxx-xxxx).
# When unset, the Pricing CTA renders in its "Checkout opens at launch"
# disabled state — useful before the LS shop is activated.
NEXT_PUBLIC_LEMONSQUEEZY_CHECKOUT_URL=""

# Reserved for future use (subscription, refund automations via the API).
# Not required for the current webhook-driven flow.
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_STORE_ID=""

# --- Resend (Milestone 5) ----------------------------------------------------
RESEND_API_KEY=""
# Verified sender, e.g. "Giuliano <[email protected]>"
RESEND_FROM=""

# --- Amplitude (Milestone 8) -------------------------------------------------
# Project API key from Amplitude (Settings → Projects → API Keys → "API
# key"). Single key per project — used by both the browser SDK (client
# bundle) and the Node SDK (server-side webhook events). Safe to expose.
NEXT_PUBLIC_AMPLITUDE_API_KEY=""

# --- Rate limiting (Milestone 10) -------------------------------------------
# Upstash Redis (REST endpoint), used for rate limiting checkout & download.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Error monitoring (Milestone 10) ----------------------------------------
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
